<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>ai.openclaw.gateway.watchdog</string>

    <key>RunAtLoad</key>
    <true/>
    <key>StartInterval</key>
    <integer>60</integer>

    <key>ProgramArguments</key>
    <array>
      <string>/Users/ymy/.openclaw/bin/gateway-watchdog.sh</string>
    </array>

    <key>StandardOutPath</key>
    <string>/Users/ymy/.openclaw/logs/gateway-watchdog.out.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/ymy/.openclaw/logs/gateway-watchdog.err.log</string>

    <key>EnvironmentVariables</key>
    <dict>
      <key>HOME</key>
      <string>/Users/ymy</string>
      <key>PATH</key>
      <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>
  </dict>
</plist>
